index 4ebd9b8c170f2e67dc8a143d364828c14a491ee7..2e2a69809602e431f11fe385855ef73bed5b85e9 100644
--- a/token_insert_ckeditor/plugins/token_insert_ckeditor/plugin.js
+++ b/token_insert_ckeditor/plugins/token_insert_ckeditor/plugin.js
@@ -3,6 +3,8 @@
 (function($) {
   "use strict";
   CKEDITOR.plugins.add('token_insert_ckeditor', {
+    requires: 'widget',
+    icons: 'TokenInsert',
     init: function(editor) {
       // Register a dialog box with CKEditor.
       CKEDITOR.dialog.add('token_insert_ckeditor_dialog', function(editor) {
@@ -19,12 +21,22 @@
               elements: [{
                 id: 'token_insert_ckeditor',
                 type: 'html',
-                html: '<div id="' + id + '" style="margin-left: 20px;"></div>'
+                html: '<div id="' + id + '" style="margin-left: 20px;"></div>',
+                commit: function (widget) {
+                  var dialog = this.getDialog();
+                  var token = dialog.token;
+                  widget.setData('token', token);
+                  $.post(Drupal.settings.basePath + 'token_replace/ajax/' + token, $('form').serialize(), function (result) {
+                    widget.setData('value', result.value);
+                    dialog.hide();
+                  }, 'json');
+                }
               }]
             }
           ],
           buttons: [CKEDITOR.dialog.cancelButton],
           onShow: function () {
+            var dialog = this;
             var editor = this.getParentEditor();
             var id = 'token-insert-' + editor.id + '-dialog-container';
             var $content = $(this.getElement('info_' + editor.id, 'token_insert_ckeditor').$);
@@ -40,8 +52,8 @@
                 var $token_link = $(this);
                 var newThis = $('<a href="javascript:void(0);" title="' + Drupal.t('Insert this token into your form') + '">' + $token_link.html() + '</a>').click(function() {
                   var $self = $(this);
-                  editor.insertText($self.text());
-                  CKEDITOR.dialog.getCurrent().hide();
+                  dialog.token = $self.text();
+                  dialog.fire('ok');
                 });
                 $token_link.html(newThis);
               });
@@ -50,13 +62,65 @@
         };
       });
 
-      // Register a command with CKeditor to launch the dialog box.
-      editor.addCommand('TokenInsert', new CKEDITOR.dialogCommand('token_insert_ckeditor_dialog'));
-      // Add a button to the CKeditor that executes a CKeditor command.
-      editor.ui.addButton('TokenInsert', {
-        label: Drupal.t('Insert a token'),
-        command: 'TokenInsert',
-        icon: this.path + 'images/insert.png'
+      // Register a widget with CKEditor.
+      editor.widgets.add('TokenInsert', {
+        button: Drupal.t('Insert a token'),
+        dialog: 'token_insert_ckeditor_dialog',
+        template: '<span class="token-insert"></span>',
+        inline: true,
+        mask: true,
+
+        // Upcast; triggered when Wysiwyg is attached (on load, switch to rich
+        // text editor, etc).
+        //
+        // Determine if an element is part of this plugin instance.
+        upcast: function (element, data) {
+          console.log('TI');
+          if (element.name == 'span' && element.hasClass('token-insert')) {
+            data.token = element.getHtml();
+            data.upcast = true;
+            return true;
+          }
+
+          else {
+            var regex = new RegExp("(\\[.*?\\])", 'g');
+            if (element.getHtml().match(regex)) {
+              element.setHtml(element.getHtml().replace(regex, "<span class='token-insert'>$1</span>"));
+            }
+          }
+
+          return false;
+        },
+
+        // Data; Insert widget markup.
+        data: function () {
+          if (typeof this.data.value != 'undefined') {
+            this.element.setHtml(this.data.value);
+          }
+          else if (typeof this.data.token != 'undefined') {
+            this.element.setHtml(this.data.token);
+          }
+
+          // If this is an upcasted widget, get the value from cache or AJAX.
+          if (typeof this.data.upcast != 'undefined') {
+            delete this.data.upcast;
+            $.post(Drupal.settings.basePath + 'token_replace/ajax/' + this.data.token, $('form').serialize(), function (result) {
+              $.each(editor.widgets.instances, function () {
+                if (this.data.token == result.token) {
+                  this.setData('value', result.value);
+                }
+              });
+            }, 'json');
+          }
+        },
+
+        // Downcast; triggered when Wysiwyg is detached (prior to submit,
+        // Switch to rich text editor, etc).
+        //
+        // Transform widget markup into filter format.
+        downcast: function (widgetElement) {
+          return new CKEDITOR.htmlParser.text(this.data.token);
+        }
       });
     }
   });
